<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FrontEnd.Components.Message">
    
    <Border Background="#ffffff" CornerRadius="8" Padding="10" Margin="5">
        <StackPanel>
          <TextBlock Text="{Binding Sender}" FontWeight="Bold" Foreground="Blue"/>
          <TextBlock Text="{Binding MessageText, Mode=OneWay}" Foreground="#000000" TextWrapping="Wrap" />
        </StackPanel>
    </Border>

</UserControl>
