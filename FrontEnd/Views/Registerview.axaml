<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FrontEnd.Views.RegisterView">
  <Border Background="Black" Padding="40">
    <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">

      <TextBlock Text="Créer un compte 📝"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="White"
                 HorizontalAlignment="Center"/>

      <!-- Bouton pour revenir à la page Login -->
      <Button Content="Se connecter"
              Command="{Binding NavigateToLoginCommand}"
              Background="Transparent"
              BorderThickness="0"
              Foreground="LightBlue"
              HorizontalAlignment="Center"
              Cursor="Hand" />

      <TextBox Watermark="Nom d’utilisateur" Text="{Binding Username, Mode=TwoWay}" />
      <TextBox Watermark="Adresse e-mail" Text="{Binding Email, Mode=TwoWay}" />
      <TextBox Watermark="Mot de passe" Text="{Binding Password, Mode=TwoWay}" PasswordChar="●" />

      <Button Content="S'inscrire"
              Command="{Binding RegisterCommand}"
              Background="#007BFF"
              Foreground="White" />

      <TextBlock Text="{Binding Message}"
           FontSize="16"
           FontWeight="SemiBold"
           Foreground="{Binding Message, Converter={StaticResource MessageToColorConverter}}"
           HorizontalAlignment="Center"
           Margin="0,20,0,0"
           TextWrapping="Wrap"
           TextAlignment="Center"/>


    </StackPanel>
  </Border>
</UserControl>
