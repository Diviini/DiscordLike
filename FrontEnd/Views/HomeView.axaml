<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FrontEnd.Views.HomeView">
  <StackPanel Margin="30" Spacing="10">

 <TextBlock Text="Bienvenue dans MyOnlyChat 💬" FontSize="24" FontWeight="Bold"/>

    <TextBlock FontSize="16">
        <Run Text="Votre Username:"/>
        <Run Text="{Binding Username}"/>
    </TextBlock>  

    <TextBlock FontSize="16">
        <Run Text="Votre Email:"/>
        <Run Text="{Binding Email}"/>
    </TextBlock>  

    <TextBlock FontSize="14">
  <Run Text="ID : "/>
  <Run Text="{Binding UserId}"/>
</TextBlock>

  </StackPanel>
</UserControl>
