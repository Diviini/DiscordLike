<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FrontEnd.Views.HomeView">
  <StackPanel Margin="30" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
    <TextBlock Text="Bienvenue sur l'accueil 🏠"
               FontSize="24"
               HorizontalAlignment="Center" />
    <TextBlock Text="Tu es connecté 👑"
               FontSize="16"
               HorizontalAlignment="Center" />
  </StackPanel>
</UserControl>
